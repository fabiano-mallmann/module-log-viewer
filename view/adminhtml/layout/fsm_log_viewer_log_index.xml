<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <update handle="styles"/>
    <body>
        <referenceContainer name="content">
            <block class="Magento\Backend\Block\Template"
                   name="fsm.logviewer.patterns.notice"
                   template="Fsm_LogViewer::log/patterns_notice.phtml">
                <arguments>
                    <argument name="view_model" xsi:type="object">Fsm\LogViewer\ViewModel\PatternsNotice</argument>
                </arguments>
            </block>
            <uiComponent name="fsm_log_viewer_log_listing"/>
        </referenceContainer>
    </body>
</page>
