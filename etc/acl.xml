<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Magento_Backend::system">
                    <resource id="Magento_Backend::tools">
                        <resource id="Fsm_LogViewer::logviewer" title="Log Viewer" sortOrder="90">
                            <resource id="Fsm_LogViewer::view" title="View Logs" sortOrder="10"/>
                            <resource id="Fsm_LogViewer::download" title="Download Logs" sortOrder="20"/>
                        </resource>
                    </resource>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
